@startuml Update Quantity Flow
participant "Cart Page" as UI
participant "useCartRows Hook" as Hook
participant "Redux Store" as Store
participant "cartSlice Reducer" as Slice
participant "localStorage (via subscribe)" as Persist

UI -> Hook: updateItemQuantity(productId, color, size, quantity)
Hook -> Store: dispatch(setQuantity(action))
Store -> Slice: setQuantity reducer
Slice -> Store: updated state
Store -> Persist: writeStoredCartRows(items)
Store -> UI: re-render via useSelector
@enduml